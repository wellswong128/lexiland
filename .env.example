VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
# Production app origin (auth callback is appended as /auth/callback automatically).
VITE_AUTH_REDIRECT_URL=https://learn.lexiland.cc
VITE_APP_URL=https://learn.lexiland.cc
# Optional override. The public client ID is bundled in src/config/googleOAuth.public.js.
VITE_GOOGLE_CLIENT_ID=

# Optional: run `npm run configure:supabase-smtp`
# Create tokens at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Optional if VITE_SUPABASE_URL is set (e.g. https://xxxx.supabase.co)
SUPABASE_PROJECT_REF=
CLOUDFLARE_API_TOKEN=
SMTP_SENDER_EMAIL=no-reply@lexiland.cc
SMTP_SENDER_NAME=力思樂園
AGNES_API_KEY=
AGNES_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_IMAGE_SIZE=1024x768
AGNES_IMAGE_TIMEOUT_MS=45000
AGNES_IMAGE_MAX_ATTEMPTS=4
AGNES_IMAGE_MAX_TEXT_CHECKS=1
AGNES_IMAGE_TEXT_CHECK_TIMEOUT_MS=12000

# Bulk import/enrich scripts call the local dev API by default (saves Vercel quota).
# Start the app first: npm run dev
APP_API_BASE_URL=http://localhost:5173
# Set ALLOW_PRODUCTION_BULK_API=1 only if you intentionally run bulk scripts against production.
# Generate locally: npm run setup:import-api-key
# Restart `npm run dev` after changing this key so the local API sees it.
# Must match the same value set on Vercel (Settings → Environment Variables), then redeploy.
IMPORT_API_KEY=

# Vercel Cron: evening task reminders (set in Vercel, sent as Authorization: Bearer ...)
CRON_SECRET=
