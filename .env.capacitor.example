# Capacitor / native app build variables
# Copy relevant values into your local .env.local or CI secrets before `npm run cap:sync`.

VITE_APP_URL=https://learn.lexiland.cc
VITE_API_BASE_URL=https://learn.lexiland.cc
VITE_AUTH_REDIRECT_URL=https://learn.lexiland.cc/auth
# Match your Xcode Bundle Identifier (Signing & Capabilities)
VITE_CAPACITOR_APP_ID=com.wellswong.lexiland
VITE_NATIVE_AUTH_REDIRECT_URL=com.wellswong.lexiland://auth/callback
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
