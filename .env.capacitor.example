# Capacitor / native app build variables
# Copy relevant values into your local .env.local before `npm run cap:sync`.

VITE_APP_URL=https://learn.lexiland.cc
VITE_API_BASE_URL=https://learn.lexiland.cc
VITE_AUTH_REDIRECT_URL=https://learn.lexiland.cc/auth
# Match android/app/build.gradle applicationId and iOS Bundle Identifier
VITE_CAPACITOR_APP_ID=com.lexiland.app
VITE_NATIVE_AUTH_REDIRECT_URL=com.lexiland.app://auth/callback
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
