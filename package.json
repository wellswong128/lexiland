{
  "name": "lexiland",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:cap": "vite build",
    "cap:sync": "npm run build:cap && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "preview": "vite preview",
    "test": "node --test tests/**/*.test.js",
    "configure:supabase-smtp": "node scripts/configure-supabase-smtp.mjs",
    "setup:import-api-key": "node scripts/setup-import-api-key.mjs",
    "wordbase:import": "bash scripts/wordbase_import/run.sh",
    "wordbase:import:dry-run": "bash scripts/wordbase_import/run.sh --dry-run --limit-images 1",
    "wordbase:fix-translations": "bash scripts/wordbase_import/run-fix-translations.sh",
    "wordbase:fix-translations:dry-run": "bash scripts/wordbase_import/run-fix-translations.sh --dry-run",
    "word-groups:seed": "node scripts/hk_word_groups/seed_word_groups.mjs",
    "word-groups:seed:dry-run": "node scripts/hk_word_groups/seed_word_groups.mjs --dry-run",
    "word-groups:import-maps": "node scripts/hk_word_groups/import_word_group_maps.mjs",
    "word-groups:import-maps:dry-run": "node scripts/hk_word_groups/import_word_group_maps.mjs --dry-run",
    "word-groups:scaffold-lists": "node scripts/hk_word_groups/scaffold_word_list_files.mjs",
    "word-groups:scaffold-lists:dry-run": "node scripts/hk_word_groups/scaffold_word_list_files.mjs --dry-run",
    "word-groups:fill-lists": "node scripts/hk_word_groups/fill_empty_word_lists.mjs",
    "word-groups:fill-lists:dry-run": "node scripts/hk_word_groups/fill_empty_word_lists.mjs --dry-run",
    "word-groups:enrich": "bash scripts/hk_word_groups/run-enrich.sh",
    "word-groups:enrich:dry-run": "bash scripts/hk_word_groups/run-enrich.sh --dry-run",
    "word-groups:enrich:p1-english": "bash scripts/hk_word_groups/run-enrich.sh --file data/hk_word_groups/primary/p1/english.json",
    "word-groups:enrich:all": "bash scripts/hk_word_groups/run-enrich.sh --all",
    "word-groups:enrich:all:dry-run": "bash scripts/hk_word_groups/run-enrich.sh --all --dry-run",
    "git:push": "bash scripts/git-push.sh origin main"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@supabase/supabase-js": "^2.108.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  }
}
